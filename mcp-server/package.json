{
  "name": "mcp-thai-thesis",
  "version": "1.0.0",
  "description": "MCP Server for Thai Thesis AI Workflow — 11 tools and 9 resources for Thai academic writing, de-AI processing, APA นาม-ปี citations, ISO 29110 documents, quality scoring, and multi-university formatting.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node --esm src/server.ts",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
