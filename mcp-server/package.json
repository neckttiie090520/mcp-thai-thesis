    "rimraf": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "keywords": [
    "mcp",
    "thai-thesis",
    "academic-writing",
    "iso29110",
    "de-ai",
    "apa-citation",
    "university",
    "thailand"
  ],
  "author": "nextzus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nextzus/mcp-thai-thesis"
